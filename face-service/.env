# URL of the SEERS Node backend.
SERVER_URL=http://localhost:4000

# Must match DEVICE_TOKEN in server/.env
DEVICE_TOKEN=seers-device-token

# Webcam index (0 = default). For an IP camera, put the RTSP/HTTP URL instead.
CAMERA_SOURCE=0

# Port this service serves its MJPEG preview on (dashboard reads /stream).
PORT=5001

# Recognition tolerance (lower = stricter). 0.6 is the dlib default.
FACE_TOLERANCE=0.5

# Seconds to wait before re-reporting the same student (debounce).
REPORT_COOLDOWN=15