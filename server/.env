# HTTP + WebSocket port the server listens on.
PORT=4000

# PostgreSQL connection string.
DATABASE_URL=postgresql://postgres:Arjaypostgre1217!@localhost:5432/seers

# Secret used to sign admin JWTs. Change this to a long random string.
JWT_SECRET= adwafafadxcawekajsdkojaisjdkamsdj

# Shared token the ESP8266 sensor and face-service present when posting data.
# Must match DEVICE_TOKEN in the firmware and face-service .env.
DEVICE_TOKEN=seers-device-token

# URL of the Python face-service, used to push/remove face enrollments.
FACE_SERVICE_URL=http://localhost:5001

# Earthquake detection: peak deviation from 1g (in g) that triggers an event.
EQ_THRESHOLD_G=0.25

# Seconds of calm below threshold before an active earthquake auto-clears.
EQ_CLEAR_SECONDS=30

